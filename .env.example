APP_NAME="Mokador ti porta in vacanza"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://invacanza.mokador.it
APP_TIMEZONE=Europe/Rome

APP_LOCALE=it
APP_FALLBACK_LOCALE=it
APP_FAKER_LOCALE=it_IT

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=mokador_concorso
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MAIL_MAILER=smtp
MAIL_SCHEME=tls
MAIL_HOST=vu000671.arubabiz.net
MAIL_PORT=587
MAIL_USERNAME=mokador@vu000671.arubabiz.net
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="concorso@mokador.it"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

# Concorso - Date inizio/fine
CONCORSO_START_DATE=2026-04-20
CONCORSO_END_DATE=2026-05-17

# Admin backoffice - Credenziali default
ADMIN_NAME="Admin Mokador"
ADMIN_EMAIL=admin@mokador.it
ADMIN_PASSWORD=changeme123

# Cloudflare Turnstile (test keys: https://developers.cloudflare.com/turnstile/troubleshooting/testing/)
TURNSTILE_SITE_KEY=1x00000000000000000000AA
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
